---
import { readdirSync } from "node:fs";
import BirthdayCake from "../components/BirthdayCake.tsx";
import BirthdayExperience from "../components/BirthdayExperience.tsx";

const photos = readdirSync(new URL("../../public/photos", import.meta.url))
  .filter((name: string) => name.toLowerCase().endsWith(".webp"))
  .sort();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Happy Birthday!</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    {
      /* BirthdayCake is hidden while the photo gallery is shown — uncomment to restore */
    }
    {/* <BirthdayCake client:load /> */}
    <BirthdayExperience photos={photos} client:load />
  </body>
</html>
